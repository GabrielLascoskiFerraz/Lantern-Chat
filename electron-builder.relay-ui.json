{
  "appId": "LanternRelay",
  "productName": "Lantern Relay",
  "directories": { "output": "dist-relay-ui-installers", "buildResources": "assets" },
  "extraMetadata": { "main": "dist-relay-ui/relay-ui/main.js" },
  "files": ["dist-relay-ui/**/*", "relay-ui/renderer/**/*", "assets/**/*", "package.json", "!node_modules/better-sqlite3/**/*"],
  "asar": true,
  "win": { "icon": "assets/icon.ico", "target": ["nsis"], "artifactName": "LanternRelay-Setup-${version}.${ext}" },
  "mac": { "icon": "assets/icon.icns", "target": ["dmg", "zip"], "artifactName": "LanternRelay-${version}-${arch}.${ext}", "category": "public.app-category.utilities" },
  "linux": { "icon": "assets/icon.png", "target": ["AppImage"], "artifactName": "LanternRelay-${version}-${arch}.${ext}", "category": "Utility" },
  "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false }
}

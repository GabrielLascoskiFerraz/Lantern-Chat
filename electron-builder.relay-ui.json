{
  "appId": "com.lantern.relay",
  "productName": "Lantern Relay",
  "directories": { "output": "dist-relay-ui-installers", "buildResources": "assets" },
  "extraMetadata": { "main": "dist-relay-ui/relay-ui/main.js" },
  "files": ["dist-relay-ui/**/*", "relay-ui/renderer/**/*", "assets/**/*", "package.json"],
  "extraResources": [
    { "from": "dist-renderer", "to": "dist-renderer", "filter": ["**/*"] }
  ],
  "asar": true,
  "asarUnpack": ["node_modules/better-sqlite3/**/*"],
  "win": { "icon": "assets/icon.ico", "target": ["nsis"], "artifactName": "LanternRelay-Setup-${version}.${ext}" },
  "mac": { "icon": "assets/icon.icns", "target": ["dmg"], "artifactName": "LanternRelay-${version}-${arch}.${ext}", "category": "public.app-category.utilities" },
  "linux": { "icon": "assets/icon.png", "target": ["AppImage"], "artifactName": "LanternRelay-${version}-${arch}.${ext}", "category": "Network" },
  "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false }
}
